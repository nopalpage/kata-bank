# ══════════════════════════════════════════════════════════════════
# Lexica — Environment Variables
# Salin file ini ke .env.local dan isi nilai yang sesuai
# JANGAN commit .env.local ke git!
# ══════════════════════════════════════════════════════════════════

# ── Supabase ────────────────────────────────────────────────────
# Ambil dari: https://app.supabase.com → Settings → API

# Public (aman diexpose ke browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# RAHASIA — hanya untuk server, JANGAN expose ke client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── App ─────────────────────────────────────────────────────────
# URL aplikasi (otomatis di Vercel via VERCEL_URL, override untuk dev)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Catatan Vercel ───────────────────────────────────────────────
# Di Vercel, tambahkan semua variabel di atas via:
#   Dashboard → Project → Settings → Environment Variables
#
# Atau via CLI: vercel env add VARIABLE_NAME
#
# Setelah deploy, update di Supabase:
#   Authentication → URL Configuration
#   Site URL: https://your-app.vercel.app
#   Redirect URLs: https://your-app.vercel.app/auth/callback
